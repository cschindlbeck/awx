#!/usr/bin/env bash

_awx_is_sourced=0
if (return 0 2>/dev/null); then _awx_is_sourced=1; fi

if [[ "$_awx_is_sourced" -eq 0 ]]; then
  set -euo pipefail
fi

DEFAULT_REGION="${DEFAULT_REGION:-${AWS_REGION:-eu-central-1}}"
DEBUG="${DEBUG:-false}" # Enable debug mode for troubleshooting

# ---------------------------------------------------------------------------
# Colour support — only emit escape codes when stdout is a TTY with 8+ colours
# ---------------------------------------------------------------------------
if [[ -t 1 ]] && tput colors &>/dev/null && [[ "$(tput colors)" -ge 8 ]]; then
  COL_INFO="$(tput setaf 2)"
  COL_WARN="$(tput setaf 3)"
  COL_ERR="$(tput setaf 1)"
  COL_RESET="$(tput sgr0)"
else
  COL_INFO=""
  COL_WARN=""
  COL_ERR=""
  COL_RESET=""
fi

AWX_EKS_RETRIES="${AWX_EKS_RETRIES:-3}"         # Retries for EKS API calls after SSO login
AWX_EKS_RETRY_DELAY="${AWX_EKS_RETRY_DELAY:-2}" # Seconds between EKS API retries
AWX_STS_RETRIES="${AWX_STS_RETRIES:-10}"        # Retries waiting for STS after SSO login
AWX_NO_ASCII="${AWX_NO_ASCII:-false}"           # Set to "true" to suppress ASCII art banner

# ---------------------------------------------------------------------------
# EKS cluster cache — avoids repeated AWS API calls
# ---------------------------------------------------------------------------
AWX_CACHE_DIR="${AWX_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/awx}"
AWX_CACHE_TTL="${AWX_CACHE_TTL:-480}" # Cache TTL in minutes (default: 8h)

# ---------------------------------------------------------------------------
# State management — persists current/previous environment for `awx -`
# ---------------------------------------------------------------------------
AWX_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/awx"
AWX_STATE_FILE="${AWX_STATE_FILE:-$AWX_STATE_DIR/env}"

_awx_state_ensure_dir() {
  mkdir -p "$(dirname "$AWX_STATE_FILE")"
}

# Write a new current env, rotating previous.
# Usage: _awx_state_write <profile> <cluster>
_awx_state_write() {
  local profile="$1"
  local cluster="${2:-}"
  local prev_current=""

  _awx_state_ensure_dir

  if [[ -f "$AWX_STATE_FILE" ]]; then
    prev_current="$(head -1 "$AWX_STATE_FILE")"
  fi

  printf "%s\n%s\n" "${profile},${cluster}" "${prev_current}" >"$AWX_STATE_FILE"
}

# Read the previous environment line. Prints "profile,cluster", empty string, or blank line.
# Callers must guard against empty/blank results.
_awx_state_read_previous() {
  if [[ ! -f "$AWX_STATE_FILE" ]]; then
    return 0
  fi
  sed -n '2p' "$AWX_STATE_FILE"
}

log() {
  printf "%s[INFO]%s %s\n" "$COL_INFO" "$COL_RESET" "$*"
}

warn() {
  printf "%s[WARN]%s %s\n" "$COL_WARN" "$COL_RESET" "$*" >&2
}

error() {
  printf "%s[ERROR]%s %s\n" "$COL_ERR" "$COL_RESET" "$*" >&2
}

die() {
  error "$*"
  return 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing dependency: $1"
}

check_deps() {
  require_cmd aws
  require_cmd fzf
  require_cmd jq
}

aws_ensure_session() {
  local profile="$1"

  # Verify SSO config first
  local sso_test_err
  sso_test_err="$(AWS_PAGER="" aws configure get sso_start_url --profile "$profile" 2>&1 || true)"
  if [[ -z "${sso_test_err// /}" ]]; then
    die "Profile '$profile' is missing required SSO configuration.\nRun: aws configure sso --profile $profile"
  fi

  if aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
    return 0
  fi

  log "SSO session expired or not authenticated for profile: $profile"
  aws sso login --profile "$profile" || die "AWS SSO login failed for profile: $profile"

  # Retry loop to wait for SSO credentials to propagate after login.
  # 10 attempts x 1s covers slow browser confirmation without hanging forever.
  local sts_ready=0
  for ((i = 0; i < AWX_STS_RETRIES; i++)); do
    if aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
      sts_ready=1
      break
    fi
    log "Waiting for SSO session to stabilize..."
    sleep 1
  done

  if [[ "$sts_ready" -eq 0 ]]; then
    die "SSO session not ready after login. Please run 'awx use' again."
    return 1
  fi
}

aws_call() {
  local profile="$1"
  shift

  aws_ensure_session "$profile"
  AWS_PAGER="" aws --profile "$profile" "$@"
}

select_profile() {
  local profiles
  profiles="$(aws configure list-profiles)"

  if [[ -z "$profiles" ]]; then
    die "No AWS profiles configured. Run: aws configure sso"
    return 1
  fi

  # No newline in the string means exactly one profile — auto-select it.
  # Command substitution strips trailing newlines, so a single profile
  # yields "name" (no newline), while multiple profiles yield "a\nb".
  if [[ "$profiles" != *$'\n'* ]]; then
    log "Auto-selecting the only available AWS profile: $profiles" >&2
    printf "%s\n" "$profiles"
    return 0
  fi

  printf "%s\n" "$profiles" | fzf --prompt="Select AWS profile: " \
    --preview 'aws configure list --profile {}'
}

_eks_cache_path() {
  local profile="$1"
  local safe_profile
  safe_profile="${profile//[^a-zA-Z0-9._-]/_}"
  printf "%s/clusters_%s.json" "$AWX_CACHE_DIR" "$safe_profile"
}

_eks_cache_valid() {
  local cache_file="$1"
  [[ -f "$cache_file" ]] || return 1
  [[ -n "$(find "$cache_file" -mmin "-${AWX_CACHE_TTL}" 2>/dev/null)" ]]
}

_eks_cache_write() {
  local cache_file="$1"
  local data="$2"
  mkdir -p "$(dirname "$cache_file")"
  printf "%s" "$data" >"$cache_file"
}

validate_and_resolve_profile() {
  local profile="$1"
  local profiles
  local matches
  local selected

  profiles="$(aws configure list-profiles)"

  if grep -Fxq "$profile" <<<"$profiles"; then
    printf "%s\n" "$profile"
    return 0
  fi

  matches="$(grep -iF "$profile" <<<"$profiles" || true)"

  if [[ -n "$matches" ]]; then
    selected="$(printf "%s\n" "$matches" | fzf --prompt="Select AWS profile: ")"
    if [[ -z "$selected" ]]; then
      warn "No profile selected; keeping current AWS_PROFILE: ${AWS_PROFILE:-<unset>}"
      return 1
    fi
    printf "%s\n" "$selected"
  else
    warn "No matching AWS profile found for '$profile'"
    return 1
  fi
}

list_clusters() {
  local profile="$1"
  local out=""
  local i
  local cache_file
  local err_file
  cache_file="$(_eks_cache_path "$profile")"

  if _eks_cache_valid "$cache_file"; then
    if [[ "$DEBUG" == "true" ]]; then
      log "EKS cluster cache hit for profile: $profile"
    fi
    jq -r '.clusters[]?' <"$cache_file"
    return 0
  fi

  err_file="$(mktemp)"

  # Ensure the SSO session is valid before attempting EKS API calls.
  # stdout is redirected to stderr so that log messages (e.g. "SSO session
  # expired") are shown to the user but do NOT flow into the stdout of this
  # function, which callers capture via $() to parse cluster names.
  aws_ensure_session "$profile" >&2 || {
    rm -f "$err_file"
    die "Session unavailable for profile: $profile"
    return 1
  }

  for ((i = 1; i <= AWX_EKS_RETRIES; i++)); do
    if out="$(AWS_PAGER="" aws --profile "$profile" eks list-clusters \
      --region "$DEFAULT_REGION" --output json 2>"$err_file")" &&
      jq -e .clusters >/dev/null 2>&1 <<<"$out"; then
      break
    fi

    if [[ $i -lt $AWX_EKS_RETRIES ]]; then
      warn "EKS API not ready yet (attempt $i/$AWX_EKS_RETRIES), retrying in ${AWX_EKS_RETRY_DELAY}s..."
      sleep "$AWX_EKS_RETRY_DELAY"
    fi
  done

  if ! jq -e .clusters >/dev/null 2>&1 <<<"$out"; then
    cat "$err_file" >&2
    rm -f "$err_file"
    die "Invalid API response: Failed to parse AWS EKS clusters. Check authentication and network connectivity."
    return 1
  fi

  if [[ "$DEBUG" == "true" ]]; then
    log "AWS RAW RESPONSE: $out"
  fi

  rm -f "$err_file"
  _eks_cache_write "$cache_file" "$out"
  jq -r '.clusters[]?' <<<"$out"
}

select_cluster_for_profile() {
  local profile="$1"
  local clusters
  local cluster_count

  clusters="$(list_clusters "$profile")"
  if [[ -z "$clusters" ]]; then
    warn "No EKS clusters found for profile: $profile"
    return 1
  fi

  cluster_count="$(printf "%s\n" "$clusters" | wc -l | tr -d ' ')"

  if [[ "$cluster_count" -eq 1 ]]; then
    printf "%s\n" "$clusters"
    return 0
  fi

  printf "%s\n" "$clusters" | fzf --prompt="Select EKS cluster: " \
    --preview "aws eks describe-cluster --name {} --region '${DEFAULT_REGION}'"
}

_kubeconfig_context_exists() {
  local context="$1"
  # Returns 0 only when kubectl is available AND the named context exists.
  # If kubectl is absent the check is skipped and update-kubeconfig always runs.
  command -v kubectl >/dev/null 2>&1 &&
    kubectl config get-contexts -o name 2>/dev/null | grep -Fxq "$context"
}

_eks_update_kubeconfig() {
  local profile="$1"
  local cluster="$2"
  local region="${3:-$DEFAULT_REGION}"

  if _kubeconfig_context_exists "$profile"; then
    log "Kubeconfig context already exists for cluster: $cluster, switching to context: $profile"
    kubectl config use-context "$profile" || die "Failed to switch to kube context: $profile"
    return 0
  fi

  log "Updating kubeconfig for cluster: $cluster"
  if AWS_PAGER="" aws --profile "$profile" eks update-kubeconfig --region "$region" --name "$cluster" --alias "$profile" 2>/tmp/kubeconfig_debug.log; then
    log "Kubeconfig updated successfully"
  else
    die "Failed to update kubeconfig for cluster: $cluster"
  fi
}

awx_use() {
  local profile=""
  local cluster=""
  local fuzzy=0

  # Parse optional flags; fall back to interactive when absent
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --profile)
        [[ -n "${2:-}" ]] || die "--profile requires a value"
        profile="$2"
        shift 2
        ;;
      --fuzzy-profile)
        # Internal flag: profile shortcut (positional arg) — triggers fuzzy resolve
        [[ -n "${2:-}" ]] || die "--fuzzy-profile requires a value"
        profile="$2"
        fuzzy=1
        shift 2
        ;;
      --cluster)
        [[ -n "${2:-}" ]] || die "--cluster requires a value"
        cluster="$2"
        shift 2
        ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  check_deps

  if [[ -z "$profile" ]]; then
    profile="$(select_profile || true)"
    if [[ -z "$profile" ]]; then
      warn "No profile selected; keeping current AWS_PROFILE: ${AWS_PROFILE:-<unset>}"
      return 1
    fi
  elif [[ "$fuzzy" -eq 1 ]]; then
    profile="$(validate_and_resolve_profile "$profile")" || return 1
  fi

  export AWS_PROFILE="$profile"
  export AWS_REGION="$DEFAULT_REGION"

  log "Using profile: $AWS_PROFILE (region: $AWS_REGION)"

  if [[ -z "$cluster" ]]; then
    if ! cluster="$(select_cluster_for_profile "$profile")"; then
      _awx_state_write "$profile" ""
      return 0
    fi
  fi

  _eks_update_kubeconfig "$profile" "$cluster" "$DEFAULT_REGION"
  _awx_state_write "$profile" "$cluster"
}

awx_whoami() {
  local profile="${AWS_PROFILE:-}"

  check_deps

  if [[ -z "$profile" ]]; then
    error "AWS_PROFILE not set. Please run: awx use"
    return 1
  fi

  aws_call "$profile" sts get-caller-identity
}

awx_profiles() {
  # Only aws is needed here (no fzf/jq), so require_cmd aws is used directly
  require_cmd aws
  local filter_profile="${1:-}"
  local profiles_out _awx_interrupted=0 _prev_int_trap

  if [[ -n "$filter_profile" ]]; then
    profiles_out="$filter_profile"
  else
    profiles_out="$(aws configure list-profiles)" || die "Failed to list AWS profiles"
  fi

  # Save existing INT trap and set our own so Ctrl+C breaks the loop cleanly.
  # This is necessary when awx is sourced: the interactive shell's SIGINT only
  # kills the foreground subprocess (aws sts), not the while loop itself.
  _prev_int_trap="$(trap -p INT)"
  trap '_awx_interrupted=1' INT

  while IFS= read -r profile; do
    if [[ "$_awx_interrupted" -eq 1 ]]; then break; fi
    if AWS_PAGER="" aws sts get-caller-identity \
      --profile "$profile" >/dev/null 2>&1; then
      printf "%-40s ACTIVE\n" "$profile"
    else
      printf "%-40s EXPIRED\n" "$profile"
    fi
  done <<<"$profiles_out"

  # Restore the previous INT trap to leave the shell in a clean state
  if [[ -n "$_prev_int_trap" ]]; then
    eval "$_prev_int_trap"
  else
    trap - INT
  fi

  if [[ "$_awx_interrupted" -eq 1 ]]; then
    return 130
  fi
}

awx_eks() {
  local subcommand="${1:-}"
  local profile="${AWS_PROFILE:-}"
  local cluster

  check_deps

  if [[ -z "$profile" ]]; then
    error "AWS_PROFILE not set. Please run: awx use"
    return 1
  fi

  if [[ -z "$subcommand" ]]; then
    error "Missing EKS subcommand. Usage: awx eks [list|update]"
    return 1
  fi

  case "$subcommand" in
    list)
      clusters="$(list_clusters "$profile")"
      if [[ -z "$clusters" ]]; then
        warn "No EKS clusters found for profile: $profile"
        return 0
      fi
      printf "%s\n" "$clusters"
      ;;
    update)
      cluster="$(select_cluster_for_profile "$profile")" || die "No EKS cluster selected"
      _eks_update_kubeconfig "$profile" "$cluster" "$DEFAULT_REGION"
      _awx_state_write "$profile" "$cluster"
      ;;
    *)
      die "Unknown eks subcommand: ${subcommand:-<empty>} (expected: list|update)"
      ;;
  esac
}

awx_update() {
  local self
  local raw_url="${AWX_UPDATE_URL:-https://raw.githubusercontent.com/cschindlbeck/awx/main/awx}"

  require_cmd curl

  self="$(readlink -f "${BASH_SOURCE[0]}")"

  [[ -z "$self" ]] && die "Could not determine awx executable path."

  if [[ ! -f "$self" ]]; then
    die "Resolved awx path is not a file: $self"
  fi

  if [[ ! -w "$self" ]]; then
    die "Cannot write to ${self}. Check file permissions."
  fi

  log "Updating awx..."
  curl -fsSL "$raw_url" -o "$self" || die "Failed to download update from ${raw_url}"
  chmod +x "$self" || die "Failed to make ${self} executable."

  log "...awx updated successfully."
  log "Reload your shell to apply the update."
}
awx_logout() {
  local profile="${AWS_PROFILE:-}"

  if [[ -z "$profile" ]]; then
    error "AWS_PROFILE not set. Please run: awx use"
    return 1
  fi

  if aws sso logout --profile "$profile" >/dev/null 2>&1; then
    unset AWS_PROFILE
    log "Logged out of SSO session and cleared AWS_PROFILE for profile: $profile"
  else
    error "Failed to log out of SSO session for profile: $profile"
    return 1
  fi
}

awx_prev() {
  local prev_line
  prev_line="$(_awx_state_read_previous)"

  # Strip whitespace/blank lines
  prev_line="${prev_line#"${prev_line%%[![:space:]]*}"}"
  prev_line="${prev_line%"${prev_line##*[![:space:]]}"}"

  if [[ -z "$prev_line" ]]; then
    warn "No previous environment recorded; staying on current profile: ${AWS_PROFILE:-<unset>}"
    return 0
  fi

  if [[ "$prev_line" != *,* ]]; then
    die "Malformed state entry: '$prev_line'. Expected 'profile,cluster' format. Delete ${AWX_STATE_FILE} to reset."
  fi

  local prev_profile prev_cluster
  prev_profile="${prev_line%%,*}"
  prev_cluster="${prev_line#*,}"

  # Guard against state file corruption where a command name was written as a
  # profile (e.g. 'awx profiles' treated as a profile shortcut before the
  # command was registered in the dispatcher).
  case "$prev_profile" in
    use | whoami | profiles | eks | logout | help | -)
      die "State file contains reserved name '$prev_profile' as a profile — likely caused by sourcing an old version of awx. Delete $AWX_STATE_FILE to reset."
      ;;
  esac

  # Swap state lines: previous becomes current, current becomes previous
  local current_line=""
  if [[ -f "$AWX_STATE_FILE" ]]; then
    current_line="$(head -1 "$AWX_STATE_FILE")"
  fi
  _awx_state_ensure_dir
  # NOTE: state is swapped before kubeconfig update. If kubeconfig fails,
  # the state file reflects the new environment even though kubeconfig was
  # not updated. Run 'awx -' again to recover or manually run 'awx use'.
  printf "%s\n%s\n" "$prev_line" "$current_line" >"$AWX_STATE_FILE"

  export AWS_PROFILE="$prev_profile"
  export AWS_REGION="$DEFAULT_REGION"
  log "Switched to profile: $AWS_PROFILE (region: $AWS_REGION)"

  if [[ -n "$prev_cluster" ]]; then
    _eks_update_kubeconfig "$prev_profile" "$prev_cluster" "$DEFAULT_REGION"
  else
    warn "No cluster stored for previous environment; kubeconfig not updated"
  fi
}

show_help() {
  if [[ "$AWX_NO_ASCII" != "true" ]]; then
    cat <<'EOF'
    ___ _       ___  __
   /   | |     / / |/ /
  / /| | | /| / /|   /
 / ___ | |/ |/ //   |
/_/  |_|__/|__//_/|_|

EOF
  fi
  echo "Usage: awx [command]"
  echo "Commands:"
  echo "  use [--profile P] [--cluster C]   Select AWS profile/cluster (interactive fallback)"
  echo "  <profile>                         Shortcut: set profile and update kubeconfig"
  echo "  whoami                            Display current AWS identity"
  echo "  profiles                          List all profiles with session status (ACTIVE/EXPIRED)"
  echo "  eks list                          List EKS clusters for the active profile"
  echo "  eks update                        Update kubeconfig for a specific EKS cluster"
  echo "  logout                            Logout of the current AWS SSO session"
  echo "  update                            Update awx to the latest version from GitHub"
  echo "  -                                 Toggle back to previous AWS profile/cluster (like cd -)"
  echo "  help | -h                         Show this help message"
}

awx() {
  local command="${1:-use}"

  case "$command" in
    use)
      if [[ $# -gt 0 ]]; then shift; fi
      awx_use "$@"
      ;;
    whoami)
      awx_whoami
      ;;
    profiles)
      if [[ $# -gt 0 ]]; then shift; fi
      awx_profiles "$@"
      ;;
    eks)
      if [[ $# -gt 0 ]]; then shift; fi
      awx_eks "$@"
      ;;
    logout)
      awx_logout
      ;;
    update)
      awx_update
      ;;
    help | -h | --help)
      show_help
      ;;
    -)
      awx_prev
      ;;
    --*)
      # Top-level flags (e.g. awx --profile X) forwarded directly to awx_use.
      awx_use "$@"
      ;;
    *)
      # Treat an unrecognised argument as a profile shortcut with fuzzy resolve.
      # e.g. `awx my-profile` triggers fuzzy/partial profile matching
      awx_use --fuzzy-profile "$command"
      ;;
  esac
}

if [[ "$_awx_is_sourced" -eq 0 ]]; then
  awx "$@"
fi
