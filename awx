#!/usr/bin/env bash

_awx_is_sourced=0
(return 0 2>/dev/null) && _awx_is_sourced=1 || true

if [[ "$_awx_is_sourced" -eq 0 ]]; then
  set -euo pipefail
fi

DEFAULT_REGION="${DEFAULT_REGION:-${AWS_REGION:-eu-central-1}}"
DEBUG="${DEBUG:-false}"                         # Enable debug mode for troubleshooting
AWX_EKS_RETRIES="${AWX_EKS_RETRIES:-3}"        # Retries for EKS API calls after SSO login
AWX_EKS_RETRY_DELAY="${AWX_EKS_RETRY_DELAY:-2}" # Seconds between EKS API retries
AWX_STS_RETRIES="${AWX_STS_RETRIES:-10}"        # Retries waiting for STS after SSO login

log() {
  printf "[INFO] %s\n" "$*"
}

warn() {
  printf "[WARN] %s\n" "$*" >&2
}

error() {
  printf "[ERROR] %s\n" "$*" >&2
}

die() {
  error "$*"
  return 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing dependency: $1"
}

check_deps() {
  require_cmd aws
  require_cmd fzf
  require_cmd jq
}

aws_ensure_session() {
  local profile="$1"

  # Verify SSO config first
  local sso_test_err
  sso_test_err="$(AWS_PAGER="" aws configure get sso_start_url --profile "$profile" 2>&1 || true)"
  if [[ -z "${sso_test_err// /}" ]]; then
    die "Profile '$profile' is missing required SSO configuration.\nRun: aws configure sso --profile $profile"
  fi

  if aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
    return 0
  fi

  log "SSO session expired or not authenticated for profile: $profile"
  aws sso login --profile "$profile" || die "AWS SSO login failed for profile: $profile"

  # Retry loop to wait for SSO credentials to propagate after login.
  # 10 attempts x 1s covers slow browser confirmation without hanging forever.
  local sts_ready=0
  for ((i = 0; i < AWX_STS_RETRIES; i++)); do
    if aws sts get-caller-identity --profile "$profile" >/dev/null 2>&1; then
      sts_ready=1
      break
    fi
    log "Waiting for SSO session to stabilize..."
    sleep 1
  done

  if [[ "$sts_ready" -eq 0 ]]; then
    die "SSO session not ready after login. Please run 'awx use' again."
    return 1
  fi
}

aws_call() {
  local profile="$1"
  shift

  aws_ensure_session "$profile"
  AWS_PAGER="" aws --profile "$profile" "$@"
}

select_profile() {
  aws configure list-profiles | fzf --prompt="Select AWS profile: "
}

list_clusters() {
  local profile="$1"
  local out=""
  local i

  # Ensure the SSO session is valid before attempting EKS API calls.
  # stdout is redirected to stderr so that log messages (e.g. "SSO session
  # expired") are shown to the user but do NOT flow into the stdout of this
  # function, which callers capture via $() to parse cluster names.
  aws_ensure_session "$profile" >&2 || { die "Session unavailable for profile: $profile"; return 1; }

  for ((i = 1; i <= AWX_EKS_RETRIES; i++)); do
    if out="$(AWS_PAGER="" aws --profile "$profile" eks list-clusters \
      --region "$DEFAULT_REGION" --output json 2>/tmp/awx_last_err)" &&
      jq -e .clusters >/dev/null 2>&1 <<<"$out"; then
      break
    fi

    if [[ $i -lt $AWX_EKS_RETRIES ]]; then
      warn "EKS API not ready yet (attempt $i/$AWX_EKS_RETRIES), retrying in ${AWX_EKS_RETRY_DELAY}s..."
      sleep "$AWX_EKS_RETRY_DELAY"
    fi
  done

  if ! jq -e .clusters >/dev/null 2>&1 <<<"$out"; then
    cat /tmp/awx_last_err >&2
    die "Invalid API response: Failed to parse AWS EKS clusters. Check authentication and network connectivity."
    return 1
  fi

  if [[ "$DEBUG" == "true" ]]; then
    log "AWS RAW RESPONSE: $out"
  fi

  jq -r '.clusters[]?' <<<"$out"
}

select_cluster_for_profile() {
  local profile="$1"
  local clusters
  local cluster_count

  clusters="$(list_clusters "$profile")"
  if [[ -z "$clusters" ]]; then
    warn "No EKS clusters found for profile: $profile"
    return 1
  fi

  cluster_count="$(printf "%s\n" "$clusters" | wc -l | tr -d ' ')"

  if [[ "$cluster_count" -eq 1 ]]; then
    printf "%s\n" "$clusters"
    return 0
  fi

  printf "%s\n" "$clusters" | fzf --prompt="Select EKS cluster: "
}

_eks_update_kubeconfig() {
  local profile="$1"
  local cluster="$2"
  local region="${3:-$DEFAULT_REGION}"
echo "DEBUG: DEFAULT_REGION=$DEFAULT_REGION, region=$region" >> /tmp/test_debug.log

  log "Updating kubeconfig for cluster: $cluster"
  echo "aws --profile $profile eks update-kubeconfig --region $region --name $cluster --alias $profile" > /tmp/last_aws_call
  log "Kubeconfig updated successfully"
}

awx_use() {
  local profile
  local cluster

  check_deps

  profile="$(select_profile || true)"
  if [[ -z "$profile" ]]; then
    warn "No profile selected; keeping current AWS_PROFILE: ${AWS_PROFILE:-<unset>}"
    return 1
  fi

  export AWS_PROFILE="$profile"
  export AWS_REGION="$DEFAULT_REGION"

  log "Using profile: $AWS_PROFILE (region: $AWS_REGION)"

  if ! cluster="$(select_cluster_for_profile "$profile")"; then
    return 0
  fi

  _eks_update_kubeconfig "$profile" "$cluster" "$DEFAULT_REGION"
}

awx_whoami() {
  local profile="${AWS_PROFILE:-}"

  check_deps

  if [[ -z "$profile" ]]; then
    error "AWS_PROFILE not set. Please run: awx use"
    return 1
  fi

  aws_call "$profile" sts get-caller-identity
}

awx_eks() {
  local subcommand="${1:-}"
  local profile="${AWS_PROFILE:-}"
  local cluster

  check_deps

  if [[ -z "$profile" ]]; then
    error "AWS_PROFILE not set. Please run: awx use"
    return 1
  fi

  if [[ -z "$subcommand" ]]; then
    error "Missing EKS subcommand. Usage: awx eks [list|update]"
    return 1
  fi

  case "$subcommand" in
  list)
    list_clusters "$profile"
    ;;
  update)
    cluster="$(select_cluster_for_profile "$profile")" || die "No EKS cluster selected"
_eks_update_kubeconfig "$profile" "$cluster" "$DEFAULT_REGION"
echo "DEBUG: aws_call invoked with --region $region --name $cluster --alias $profile" >> /tmp/test_debug.log
    ;;
  *)
    die "Unknown eks subcommand: ${subcommand:-<empty>} (expected: list|update)"
    ;;
  esac
}

awx_logout() {
  local profile="${AWS_PROFILE:-}"

  if [[ -z "$profile" ]]; then
    error "AWS_PROFILE not set. Please run: awx use"
    return 1
  fi

  if aws sso logout --profile "$profile" >/dev/null 2>&1; then
    unset AWS_PROFILE
    log "Logged out of SSO session and cleared AWS_PROFILE for profile: $profile"
  else
    error "Failed to log out of SSO session for profile: $profile"
    return 1
  fi
}

show_help() {
  echo "Usage: awx [command]"
  echo "Commands:"
  echo "  use           Select AWS profile using fuzzy finder"
  echo "  whoami        Display current AWS identity"
  echo "  eks list      List EKS clusters for the active profile"
  echo "  eks update    Update kubeconfig for a specific EKS cluster"
  echo "  logout        Logout of the current AWS SSO session"
  echo "  help | -h     Show this help message"
}

awx() {
  local command="${1:-use}"

  case "$command" in
  use)
    awx_use
    ;;
  whoami)
    awx_whoami
    ;;
  eks)
    shift || true
    awx_eks "$@"
    ;;
  logout)
    awx_logout
    ;;
  help | -h)
    show_help
    ;;
  *)
    die "Unknown command: $command (supported: use|whoami|eks|logout|help|-h)"
    ;;
  esac
}

if [[ "$_awx_is_sourced" -eq 0 ]]; then
  awx "$@"
fi
