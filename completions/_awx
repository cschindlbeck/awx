#compdef awx

# Zsh completion for awx
# Install (Oh My Zsh):
#   mkdir -p ~/.oh-my-zsh/completions
#   cp completions/_awx ~/.oh-my-zsh/completions/
#
# Install (plain zsh, add to ~/.zshrc):
#   fpath=(/path/to/awx/completions $fpath)
#   autoload -Uz compinit && compinit

_awx() {
  local -a commands profiles

  commands=(
    'use:Select AWS profile and update kubeconfig'
    'whoami:Display current AWS identity'
    'profiles:List all configured profiles with session status'
    'eks:Manage EKS clusters'
    'logout:Logout of current AWS SSO session'
    'help:Show help message'
  )

  _arguments \
    '1: :->command' \
    '*: :->args'

  case $state in
    command)
      profiles=(${(f)"$(aws configure list-profiles 2>/dev/null)"})
      _describe 'command' commands
      _describe 'profile shortcut' profiles
      ;;
    args)
      case $words[2] in
        use)
          _arguments \
            '--profile[AWS profile name]:profile:(${(f)"$(aws configure list-profiles 2>/dev/null)"})' \
            '--cluster[EKS cluster name]:cluster:'
          ;;
        --profile)
          profiles=(${(f)"$(aws configure list-profiles 2>/dev/null)"})
          _describe 'profile' profiles
          ;;
        eks)
          local -a eks_cmds
          eks_cmds=(
            'list:List EKS clusters for the active profile'
            'update:Update kubeconfig for a specific EKS cluster'
          )
          _describe 'eks subcommand' eks_cmds
          ;;
      esac
      ;;
  esac
}

_awx "$@"
